            <p class="hero-subtitle">We deliver cutting-edge solutions tailored to your unique needs, helping you achieve excellence in every aspect of your business.</p>
            <div class="hero-actions">
                <a href="/contact" class="btn btn-primary">Get Started</a>
                <a href="/services" class="btn btn-secondary">Learn More</a>
            </div>
        </div>
    </section>

    <section class="features-section">
