{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Email Provider Configuration
  "EmailProvider": {
    "Provider": "MicrosoftGraph",
    "FallbackProvider": "SendGrid",
    "EnableFallback": false,
    "FromAddress": "chad_solomon@catalystsoftwaresolutions.com",
    "FromName": "Catalyst Software Solutions"
  },

  // Microsoft Graph Configuration (for Microsoft 365 email)
  // All values should be stored in User Secrets (local) or Azure Environment Variables (production)
  "MicrosoftGraph": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": ""
  },

  // Azure Communication Services Configuration (better for transactional emails)
  // Connection string should be stored in User Secrets (local) or Azure Environment Variables (production)
  "AzureCommunicationServices": {
    "ConnectionString": ""
  },

  // SendGrid Configuration
  // API key should be stored in User Secrets (local) or Azure Environment Variables (production)
  "SendGrid": {
    "ApiKey": ""
  }
}
