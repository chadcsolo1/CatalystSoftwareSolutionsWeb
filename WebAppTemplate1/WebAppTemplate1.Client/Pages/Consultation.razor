@code {
    private int currentStep = 1;
    private bool isBooked = false;
    private bool isSubmitting = false;
    private bool isLoadingTimes = false;
    private DateTime? selectedDate;
    private string selectedTime = string.Empty;
    private string fullName = string.Empty;
    private string email = string.Empty;
    private string phone = string.Empty;
    private string company = string.Empty;
    private string message = string.Empty;
    private string errorMessage = string.Empty;
    private DateTime currentMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);

    private List<string> availableTimes = new List<string>();

    private class CalendarDay
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsPast { get; set; }
        public bool IsWeekend { get; set; }
    }

    private List<CalendarDay> GetCalendarDays()
    {
        var days = new List<CalendarDay>();
        var firstDayOfMonth = new DateTime(currentMonth.Year, currentMonth.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
        var startDate = firstDayOfMonth.AddDays(-(int)firstDayOfMonth.DayOfWeek);

        for (int i = 0; i < 42; i++)
        {
            var date = startDate.AddDays(i);
            days.Add(new CalendarDay
            {
                Date = date,
                IsCurrentMonth = date.Month == currentMonth.Month,
                IsPast = date.Date < DateTime.Now.Date,
                IsWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday
            });
        }

        return days;
    }

    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
    }

    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
    }

    private async Task SelectDate(CalendarDay day)
    {
        if (day.IsPast || !day.IsCurrentMonth)
            return;

        selectedDate = day.Date;
        selectedTime = string.Empty; // Clear selected time when date changes
        errorMessage = string.Empty;

        // Load available times for the selected date
        await LoadAvailableTimesAsync();
    }

    private void SelectTime(string time)
    {
        selectedTime = time;
        errorMessage = string.Empty;
    }

    private async Task LoadAvailableTimesAsync()
    {
        if (!selectedDate.HasValue)
        {
            availableTimes.Clear();
            return;
        }

        isLoadingTimes = true;
        errorMessage = string.Empty;

        try
        {
            var dateParam = selectedDate.Value.ToString("yyyy-MM-dd");
            var response = await Http.GetFromJsonAsync<AvailableTimesResponse>($"/api/consultation/available-times?date={dateParam}");

            if (response != null && response.Success)
            {
                availableTimes = response.AvailableSlots ?? new List<string>();

                if (availableTimes.Count == 0)
                {
                    errorMessage = "No available times for this date. Please select another date.";
                }
            }
            else
            {
                availableTimes.Clear();
                errorMessage = "Unable to load available times. Please try again.";
            }
        }
        catch (Exception)
        {
            availableTimes.Clear();
            errorMessage = "Error loading available times. Please try again or select another date.";
        }
        finally
        {
            isLoadingTimes = false;
        }
    }

    private class AvailableTimesResponse
    {
        public bool Success { get; set; }
        public List<string> AvailableSlots { get; set; } = new();
        public bool CalendarIntegrated { get; set; }
    }

    private void GoToStep1()
    {
        currentStep = 1;
        errorMessage = string.Empty;
    }

    private void GoToStep2()
    {
        errorMessage = string.Empty;

        if (!selectedDate.HasValue)
        {
            errorMessage = "Please select a date for your consultation.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedTime))
        {
            errorMessage = "Please select a time for your consultation.";
            return;
        }

        currentStep = 2;
    }

    private void GoToStep3()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(fullName))
        {
            errorMessage = "Please enter your full name.";
            return;
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Please enter your email address.";
            return;
        }

        if (string.IsNullOrWhiteSpace(phone))
        {
            errorMessage = "Please enter your phone number.";
            return;
        }

        currentStep = 3;
    }

    private async Task ConfirmBooking()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        errorMessage = string.Empty;

        try
        {
            var booking = new
            {
                FullName = fullName,
                Email = email,
                Phone = phone,
                Company = company,
                Message = message,
                ConsultationDate = selectedDate!.Value,
                ConsultationTime = selectedTime
            };

            var response = await Http.PostAsJsonAsync("/api/consultation/book", booking);

            if (response.IsSuccessStatusCode)
            {
                isBooked = true;
            }
            else
            {
                errorMessage = "Unable to confirm your booking. Please try again or contact us directly.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while booking your consultation. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void BookAnother()
    {
        currentStep = 1;
        isBooked = false;
        selectedDate = null;
        selectedTime = string.Empty;
        fullName = string.Empty;
        email = string.Empty;
        phone = string.Empty;
        company = string.Empty;
        message = string.Empty;
        errorMessage = string.Empty;
        currentMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    }
}
