@page "/about"

<PageTitle>About Us</PageTitle>

<div class="about-container">
    <section class="about-hero">
        <div class="hero-content">
            <h1>About Our Company</h1>
            <p class="lead">Empowering businesses through innovation and excellence since 2008</p>
        </div>
    </section>

    <section class="about-story">
        <div class="content-wrapper">
            <div class="story-grid">
                <div class="story-text">
                    <h2>Our Story</h2>
                    <p>Founded with a vision to transform how businesses operate in the digital age, we've grown from a small startup to a trusted partner for hundreds of companies worldwide.</p>
                    <p>Our journey has been marked by continuous innovation, unwavering commitment to quality, and a deep understanding of our clients' needs. Every solution we create is built on years of expertise and a passion for excellence.</p>
                </div>
                <div class="story-image">
                    <div class="image-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                            <line x1="12" y1="22.08" x2="12" y2="12"></line>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="about-mission">
        <div class="content-wrapper">
            <h2>Our Mission</h2>
            <p class="mission-statement">To deliver innovative solutions that drive measurable results, empower teams, and create lasting value for our clients and their customers.</p>
        </div>
    </section>

    <section class="about-values">
        <div class="content-wrapper">
            <h2>Our Values</h2>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                            <path d="M2 17l10 5 10-5"></path>
                            <path d="M2 12l10 5 10-5"></path>
                        </svg>
                    </div>
                    <h3>Innovation</h3>
                    <p>We constantly push boundaries and explore new technologies to stay ahead of the curve.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <h3>Collaboration</h3>
                    <p>We believe in the power of teamwork and building strong partnerships with our clients.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <h3>Excellence</h3>
                    <p>We are committed to delivering the highest quality in everything we do.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                    </div>
                    <h3>Integrity</h3>
                    <p>We operate with transparency, honesty, and accountability in all our relationships.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="about-team">
        <div class="content-wrapper">
            <h2>Our Team</h2>
            <p class="team-intro">We're a diverse group of passionate professionals dedicated to helping you succeed.</p>
            <div class="team-stats">
                <div class="stat">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Team Members</div>
                </div>
                <div class="stat">
                    <div class="stat-number">20+</div>
                    <div class="stat-label">Countries Represented</div>
                </div>
                <div class="stat">
                    <div class="stat-number">15+</div>
                    <div class="stat-label">Years Average Experience</div>
                </div>
            </div>
        </div>
    </section>

    <section class="about-cta">
        <div class="content-wrapper">
            <h2>Ready to Work Together?</h2>
            <p>Let's discuss how we can help transform your business.</p>
            <a href="/contact" class="btn-primary">Get in Touch</a>
        </div>
    </section>
</div>

<style>
    .about-container {
        width: 100%;
    }

    .about-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 100px 20px;
        text-align: center;
    }

    .hero-content h1 {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .lead {
        font-size: 1.5rem;
        opacity: 0.95;
    }

    .content-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .about-story {
        padding: 80px 20px;
        background: white;
    }

    .story-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .story-text h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 24px;
    }

    .story-text p {
        font-size: 1.125rem;
        color: #718096;
        line-height: 1.8;
        margin-bottom: 16px;
    }

    .story-image {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .image-placeholder {
        width: 100%;
        height: 400px;
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #667eea;
    }

    .about-mission {
        padding: 80px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-align: center;
    }

    .about-mission h2 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .mission-statement {
        font-size: 1.5rem;
        line-height: 1.8;
        max-width: 900px;
        margin: 0 auto;
        opacity: 0.95;
    }

    .about-values {
        padding: 80px 20px;
        background: #f8f9fa;
    }

    .about-values h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3748;
        text-align: center;
        margin-bottom: 60px;
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 32px;
    }

    .value-card {
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

    .value-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
    }

    .value-icon {
        color: #FF6B35;
        margin-bottom: 20px;
    }

    .value-card h3 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 12px;
    }

    .value-card p {
        color: #718096;
        line-height: 1.6;
    }

    .about-team {
        padding: 80px 20px;
        background: white;
        text-align: center;
    }

    .about-team h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 16px;
    }

    .team-intro {
        font-size: 1.125rem;
        color: #718096;
        margin-bottom: 60px;
    }

    .team-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
        max-width: 900px;
        margin: 0 auto;
    }

    .stat {
        padding: 20px;
    }

    .stat-number {
        font-size: 3rem;
        font-weight: 700;
        color: #667eea;
        margin-bottom: 8px;
    }

    .stat-label {
        font-size: 1rem;
        color: #718096;
        font-weight: 500;
    }

    .about-cta {
        padding: 80px 20px;
        background: linear-gradient(135deg, #FF6B35 0%, #0066CC 100%);
        color: white;
        text-align: center;
    }

    .about-cta h2 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .about-cta p {
        font-size: 1.25rem;
        margin-bottom: 32px;
        opacity: 0.95;
    }

    .btn-primary {
        display: inline-block;
        padding: 14px 32px;
        background: white;
        color: #667eea;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    }

    @@media (max-width: 768px) {
        .hero-content h1 {
            font-size: 2.5rem;
        }

        .lead {
            font-size: 1.25rem;
        }

        .story-grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .story-text h2,
        .about-mission h2,
        .about-values h2,
        .about-team h2,
        .about-cta h2 {
            font-size: 2rem;
        }

        .mission-statement {
            font-size: 1.25rem;
        }

        .image-placeholder {
            height: 300px;
        }
    }
</style>

