@page "/process"
@rendermode InteractiveWebAssembly

<PageTitle>Our Process - Catalyst Software Solutions</PageTitle>

<div class="process-page">
    <!-- Hero Section -->
    <section class="process-hero">
        <div class="hero-content">
            <h1>Our Process</h1>
            <p class="lead">A collaborative approach designed to deliver solutions that truly fit your vision</p>
        </div>
    </section>

    <!-- Core Principle -->
    <section class="core-principle">
        <div class="container">
            <div class="principle-card">
                <div class="principle-icon">💡</div>
                <h2>Core Principle</h2>
                <p>"We collaborate continuously — as many check‑ins as needed — to ensure every solution truly fits the client's vision."</p>
            </div>
        </div>
    </section>

    <!-- Process Steps -->
    <section class="process-steps">
        <div class="container">
            <div class="section-intro">
                <h2>How We Work Together</h2>
                <p>Our proven 8-step process ensures transparency, quality, and alignment at every stage</p>
            </div>

            <div class="steps-container">
                <!-- Step 1 -->
                <div class="step-card">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <div class="step-icon">⚙️</div>
                        <h3>Discovery & Consultation</h3>
                        <p>Initial meeting to understand the client's goals, challenges, and vision.</p>
                        <ul class="step-details">
                            <li>Discuss business objectives, workflows, and desired outcomes</li>
                            <li>Identify opportunities for automation, modernization, or custom development</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Project summary and initial scope outline
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="step-card">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <div class="step-icon">📋</div>
                        <h3>Requirements & Planning</h3>
                        <p>Deep‑dive sessions to define functional and technical requirements.</p>
                        <ul class="step-details">
                            <li>Establish success metrics, timelines, and milestones</li>
                            <li>Create a project roadmap with clear deliverables and review checkpoints</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Detailed project plan and proposal
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="step-card">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <div class="step-icon">🎨</div>
                        <h3>Design & Architecture</h3>
                        <p>Develop system architecture and UI/UX concepts.</p>
                        <ul class="step-details">
                            <li>Present wireframes or prototypes for client feedback</li>
                            <li>Iterate until the design aligns perfectly with client expectations</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Approved design and architecture documentation
                        </div>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="step-card">
                    <div class="step-number">4</div>
                    <div class="step-content">
                        <div class="step-icon">💻</div>
                        <h3>Development & Implementation</h3>
                        <p>Begin coding and integration based on approved specifications.</p>
                        <ul class="step-details">
                            <li>Maintain open communication with the client through regular check‑ins</li>
                            <li>Conduct milestone reviews to ensure alignment with goals</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Working builds or feature demos at each milestone
                        </div>
                    </div>
                </div>

                <!-- Step 5 -->
                <div class="step-card">
                    <div class="step-number">5</div>
                    <div class="step-content">
                        <div class="step-icon">🔍</div>
                        <h3>Review & Refinement</h3>
                        <p>Schedule as many client review sessions as needed — no limit.</p>
                        <ul class="step-details">
                            <li>Gather feedback, refine features, and adjust scope if necessary</li>
                            <li>Ensure the solution meets both functional and business needs</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Finalized, client‑approved product
                        </div>
                    </div>
                </div>

                <!-- Step 6 -->
                <div class="step-card">
                    <div class="step-number">6</div>
                    <div class="step-content">
                        <div class="step-icon">✅</div>
                        <h3>Testing & Quality Assurance</h3>
                        <p>Perform thorough testing: unit, integration, and user acceptance.</p>
                        <ul class="step-details">
                            <li>Validate performance, security, and compliance requirements</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Test reports and verified production‑ready build
                        </div>
                    </div>
                </div>

                <!-- Step 7 -->
                <div class="step-card">
                    <div class="step-number">7</div>
                    <div class="step-content">
                        <div class="step-icon">🚀</div>
                        <h3>Deployment & Delivery</h3>
                        <p>Deploy the solution to production or client environment.</p>
                        <ul class="step-details">
                            <li>Provide documentation, training, and post‑launch support</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Live system and handover package
                        </div>
                    </div>
                </div>

                <!-- Step 8 -->
                <div class="step-card">
                    <div class="step-number">8</div>
                    <div class="step-content">
                        <div class="step-icon">🤝</div>
                        <h3>Ongoing Support & Partnership</h3>
                        <p>Offer maintenance, updates, and future enhancements.</p>
                        <ul class="step-details">
                            <li>Continue periodic check‑ins to ensure long‑term success</li>
                        </ul>
                        <div class="deliverable">
                            <strong>Deliverable:</strong> Support plan and continuous improvement roadmap
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="process-cta">
        <div class="container">
            <h2>Ready to Get Started?</h2>
            <p>Let's discuss how our process can bring your vision to life</p>
            <a href="/consultation" class="btn-primary">Schedule a Consultation</a>
        </div>
    </section>
</div>

<style>
    .process-page {
        min-height: 100vh;
    }

    /* Hero Section */
    .process-hero {
        background: linear-gradient(135deg, var(--catalyst-orange) 0%, var(--catalyst-blue) 100%);
        color: white;
        padding: 100px 20px;
        text-align: center;
    }

    .hero-content h1 {
        font-size: 3.5rem;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .lead {
        font-size: 1.5rem;
        opacity: 0.95;
        max-width: 800px;
        margin: 0 auto;
    }

    /* Core Principle */
    .core-principle {
        padding: 80px 20px;
        background: var(--off-white);
    }

    .principle-card {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        padding: 60px;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        text-align: center;
    }

    .principle-icon {
        font-size: 4rem;
        margin-bottom: 24px;
    }

    .principle-card h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--deep-navy);
        margin-bottom: 24px;
    }

    .principle-card p {
        font-size: 1.5rem;
        line-height: 1.8;
        color: var(--catalyst-blue);
        font-style: italic;
        font-weight: 500;
    }

    /* Process Steps */
    .process-steps {
        padding: 80px 20px;
        background: white;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-intro {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-intro h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--deep-navy);
        margin-bottom: 16px;
    }

    .section-intro p {
        font-size: 1.25rem;
        color: #718096;
    }

    .steps-container {
        display: grid;
        gap: 40px;
    }

    .step-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 32px;
        background: white;
        padding: 40px;
        border-radius: 12px;
        border: 2px solid var(--off-white);
        transition: all 0.3s ease;
        position: relative;
    }

    .step-card:hover {
        border-color: var(--catalyst-orange);
        box-shadow: 0 8px 24px rgba(242, 106, 44, 0.15);
        transform: translateY(-4px);
    }

    .step-number {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--catalyst-orange) 0%, var(--catalyst-blue) 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .step-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .step-icon {
        font-size: 2.5rem;
    }

    .step-content h3 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--deep-navy);
        margin: 0;
    }

    .step-content > p {
        font-size: 1.125rem;
        color: #4a5568;
        line-height: 1.6;
        margin: 0;
    }

    .step-details {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .step-details li {
        font-size: 1rem;
        color: #718096;
        padding-left: 28px;
        position: relative;
        line-height: 1.6;
    }

    .step-details li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--catalyst-orange);
        font-weight: 700;
    }

    .deliverable {
        padding: 16px;
        background: var(--off-white);
        border-radius: 8px;
        border-left: 4px solid var(--catalyst-blue);
        font-size: 1rem;
        color: #4a5568;
    }

    .deliverable strong {
        color: var(--catalyst-blue);
        font-weight: 600;
    }

    /* CTA Section */
    .process-cta {
        padding: 80px 20px;
        background: linear-gradient(135deg, var(--catalyst-orange) 0%, var(--catalyst-blue) 100%);
        color: white;
        text-align: center;
    }

    .process-cta h2 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .process-cta p {
        font-size: 1.25rem;
        margin-bottom: 32px;
        opacity: 0.95;
    }

    .btn-primary {
        display: inline-block;
        padding: 16px 40px;
        background: white;
        color: var(--catalyst-blue);
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.125rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        color: var(--deep-navy);
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .hero-content h1 {
            font-size: 2.5rem;
        }

        .lead {
            font-size: 1.25rem;
        }

        .principle-card {
            padding: 40px 24px;
        }

        .principle-card h2 {
            font-size: 2rem;
        }

        .principle-card p {
            font-size: 1.25rem;
        }

        .section-intro h2 {
            font-size: 2rem;
        }

        .step-card {
            grid-template-columns: 1fr;
            gap: 24px;
            padding: 32px 24px;
        }

        .step-number {
            width: 60px;
            height: 60px;
            font-size: 1.5rem;
            margin: 0 auto;
        }

        .step-content {
            text-align: center;
        }

        .step-details li {
            text-align: left;
        }

        .process-cta h2 {
            font-size: 2rem;
        }

        .process-cta p {
            font-size: 1.125rem;
        }
    }
</style>
